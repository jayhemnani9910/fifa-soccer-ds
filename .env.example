# The application code reads process environment variables only (os.environ /
# os.getenv). Copying this file to .env does NOT load it automatically: no
# dotenv import exists in src/, and only the Compose "dev" profile wires .env
# in (via env_file, optional). To actually apply these values, either export
# them into your shell before running `make run` / `make run-pipeline` /
# pytest, or run `docker compose --profile dev up dev`, which reads .env.

# Local ports and development-container ownership
APP_PORT=8000
APP_BUILD_TARGET=production
APP_YOLO_WEIGHTS=/app/models/yolov8n.pt
APP_MLFLOW_TRACKING_URI=sqlite:////app/state/mlflow.db
MLFLOW_PORT=5000
LOCAL_UID=1000
LOCAL_GID=1000

# Analysis limits and writable output location
ANALYSIS_OUTPUT_ROOT=outputs
MAX_ACTIVE_ANALYSES=3
MAX_TASK_HISTORY=200
YOUTUBE_MAX_DOWNLOAD_BYTES=1073741824
API_REQUIRE_KEY=false
API_KEY=

# Model selection. Paths/identifiers must resolve in the running environment.
YOLO_WEIGHTS=yolov8n.pt
GNN_WEIGHTS=

# Optional integrations
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=fifa-soccer-analytics
MLFLOW_REQUIRED=false

# Browser and live-stream allowlists. Keep private RTSP disabled for public APIs.
CORS_ALLOWED_ORIGINS=
RTSP_ALLOWED_HOSTS=
RTSP_ALLOW_PRIVATE=false

# Development server only; production containers set their own bind address.
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=false
